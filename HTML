<script>
function sendLocationEmail() {
    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
            function(position) {
                const latitude = position.coords.latitude;
                const longitude = position.coords.longitude;

                const subject = encodeURIComponent("Asset GPS Location");
                const body = encodeURIComponent(
                    "Asset location coordinates:\n\n" +
                    "Latitude: " + latitude + "\n" +
                    "Longitude: " + longitude + "\n\n" +
                    "Google Maps Link:\n" +
                    "https://www.google.com/maps?q=" + latitude + "," + longitude
                );

                window.location.href = `mailto:asset.mgmt@auroramediacanada.ca?subject=${subject}&body=${body}`;
            },
            function(error) {
                alert("Unable to retrieve GPS location. Please allow location access.");
            }
        );
    } else {
        alert("Geolocation is not supported by this device/browser.");
    }
}
</script>
            <p class="iconColor">Send Location</p>
